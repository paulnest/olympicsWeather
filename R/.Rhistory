perform_request <- function(lat, lon) {
response_table <-
request(url) |>
req_url_query(latitude = lat, longitude = lon,
hourly = c("temperature_2m",
"apparent_temperature",
"precipitation_probability",
"precipitation"),
.multi="comma") |>
req_perform() |>
resp_body_json() |>
as_tibble()
return(response_table)
}
perform_request(48.85, 2.35)
